# Temper Configuration

# Stack: auto-detect from project files
# Override: spring-boot, react-ts, node-express, fastapi, go, rust
stack: auto

# Enabled packs (loaded during review)
# Packs are resolved from three tiers: project .claude/packs/ > global ~/.claude/packs/ > built-in $CLAUDE_PLUGIN_ROOT/.claude/packs/
# Global config location: ~/.claude/temper.config (packs listed there are available across all projects)
packs:
  - quality
  - tdd
  - security
  - git
  - name: production-review
    link: skill://production-review
  - name: playground
    link: plugin://playground
  #
  # Optional new packs (v5.0.0)
  - api-design
  - architecture-depth
  - performance
  - adaptive-learning
  # - name: code-simplifier
  #   link: plugin://code-simplifier
  #   # Requires plugin://code-simplifier to be installed; uncomment once available
  #
  # Extended format examples (mix freely with simple strings):
  #
  # Phase-scoped pack (only active during specific phases):
  # - name: tdd
  #   phases: [build]
  #
  # Pack linked to external plugin:
  # - name: api-standards
  #   link: plugin://my-api-linter
  #   phases: [review, check]
  #
  # Pack linked to external skill:
  # - name: security-scan
  #   link: skill://security-review
  #   phases: [review]
  #
  # Disable a global pack at project level:
  # - name: company-standards
  #   enabled: false

# Review settings
review:
  block-on: [critical]
  auto-fix: true
  confidence-threshold: 0.7

# MCP tools settings
tools:
  mode: auto            # auto | heuristic-only | require
  label-findings: true  # Show [PROVEN]/[HEURISTIC]/[SEMANTIC] labels

# Check settings
check:
  coverage-threshold: 80
  debt-tracking: true
  live-scenarios: prompt    # prompt | always | never

# Branch conventions
branch:
  pattern: "feature/{ticket}-{description}"
  commit-style: conventional

# ============================================================
# Agentic SDLC Enhancement (v4.0.0)
# Enabled by default — this IS the v4.0 experience
# ============================================================

# Phase configuration
phases:
  design: true         # Design stage for complex/medium features (auto-skipped for simple)

# Feedback loops
feedback:
  enabled: true        # Feedback loops between stages
  max-loops: 2         # Max auto-fix loops before pausing (Review→Build, Check→Build)
  check-to-build: true # Check failures create targeted fix tasks

# Observability
observability:
  enabled: true        # Track per-stage metrics
  track-tokens: true   # Track token usage per stage, incl. cached_input when tokens.cache.enabled (source: measured where harness exposes usage, else estimated)
  track-latency: true  # Track wall-clock time per stage
  track-tool-calls: true # Track MCP tool invocations per stage

# ============================================================
# Capabilities (v5.0.0)
# Each capability is independently optional and enabled by default.
# Graceful degradation — set any to false to hide its gate option everywhere.
# (Teach Me has no toggle — it is always on at every stage gate it applies to.)
# ============================================================
capabilities:
  architecture-depth: true    # Architecture depth review in review stage
  grill-me: true              # Socratic challenge at Plan/Design gates
  config-suggestions: true    # CLAUDE.md/AGENTS.md suggestions after Check
  html-review: true           # Interactive HTML plan review
  evals: true                 # Behavioral verification (Eval stage + /temper:eval)

# ============================================================
# Nested agents (v5.1.0)
# Depth budget governance for Claude Code's nested subagent support
# ============================================================
agents:
  nested: true                # allow stages to spawn child agents (default: true)
  max-depth: 4                # Temper's self-imposed cap (platform hard cap = 5)
  parallel-width: 3           # max concurrent children per stage
  on-budget-exhausted: inline # fallback when depth_remaining <= 1: inline | fail

# ============================================================
# Eval / Verification (v5.5.0)
# Behavioral verification layer between Check and commit.
# Default-on with graceful degradation: missing evalset.json or
# unavailable judge model => one-line skip/fallback, never a hard error.
# ============================================================
eval:
  enabled: true              # stage runs; set false to skip entirely (one-line notice, no subprocess)
  block-on: [task_success]   # dimensions whose failure offers the Eval->Build Re-run loop
  pass-threshold: 0.75       # aggregate score >= this => passed
  judge-model: tier-fast     # cheaper/faster model tier for the LM-judge (eval-judge skill)

# ============================================================
# Intelligent model routing (v5.6.0) — Deliverable 1, Phase 2
# Default-on with graceful degradation: when enabled is false/absent,
# behavior is byte-identical to v5.5.0 (no model param emitted on
# Agent launches; session model inherited everywhere).
# Tier names use the tier- prefix to match eval.judge-model: tier-fast.
# ============================================================
models:
  enabled: true
  tiers:
    frontier: claude-opus          # planning, design, architecture, hard implementation
    standard: claude-sonnet        # build, fixes, exploration
    fast:     claude-haiku         # test-gen, review style/lint pass, eval judge, check monitoring
  routing:
    plan:    tier-frontier
    design:  tier-frontier
    build:   tier-standard
    review:  tier-fast             # style/lint sweep; escalate-on findings re-judged on tier-frontier
    check:   tier-fast
    eval:    tier-fast             # LM-judge — the canonical "route to small model" task
  escalate-on:                    # when a fast tier hits these, re-run on tier-frontier
    - architecture-finding
    - correctness-risk
  respect-user-override: true     # never silently replace a user-set model; log source "user-override"
  drift-threshold: 2              # std-dev beyond which a stage is flagged in drift_flags (SUGGEST)

# ============================================================
# Token Efficiency & Loop Engineering (v5.9.0) — Phase 3
# Three independent, composable levers layered on the v5.6.0
# model-routing foundation. Default-on with INDEPENDENT graceful
# degradation: each sub-feature degrades byte-identically to v5.8.0
# when its flag is off. Disabling cache does NOT disable
# adaptive-depth or loops. See reference/tokenomics.md + the
# degradation contract in reference/orchestrator-patterns.md.
# ============================================================
tokens:
  cache:
    enabled: true        # true => stage agents read cacheable context first (stable prefix);
                         # false => reads exactly as v5.8.0 (no prefix rule, no cached_input field)
    scope: methodology   # which reads form the cacheable prefix (methodology = refs + config;
                         # do not widen per release without a schema bump)
  adaptive-depth:
    enabled: true        # true => trivial/simple changes run reduced pipelines (see Pipeline Depth table
                         # in reference/orchestrator-patterns.md); false => full 6-stage pipeline for every
                         # complexity (byte-identical to v5.8.0)
    floor: simple        # clamp the effective tier UP. simple = allow trivial fast-path; medium = kill
                         # trivial (clamp to medium minimum); complex = full pipeline always. A floor is a
                         # clamp, NOT a toggle — it does not disable adaptive-depth.
  loops:
    inline-threshold: 3  # files_touched <= this AND all findings auto-fixable => inline micro-fix
                         # (no subprocess). 0 => inline path never selected (full re-launch always)
    fix-mode: true       # true => minimal-context fix agent (fix list + changed files only; fix-mode
                         # preamble replaces build.md) when above inline-threshold; false => every loop
                         # is a full Build re-launch (byte-identical to v5.8.0 loop behavior)

# ============================================================
# Autonomous Continuation
# Armed by a human at the PLAN GATE, never at invocation. /temper always
# runs Plan first and stops for human review; after approval the human may
# let the remaining stages run unattended. Default behavior is unchanged:
# with this block absent, the plan gate offers only the usual stage-by-stage
# continuation (byte-identical to v5.9.0).
# ============================================================
autonomy:
  enabled: true              # false => plan gate offers only stage-by-stage; no gate annotation
  default-choice: interactive # plan-gate continuation pre-highlighted: interactive | auto

  # --- Self-judgment safeguards (§4) ---
  conservative-bias: true    # uncertain proceed/park signal => park. Confidence reuses review.confidence-threshold.

  # --- Safety envelope ---
  stop-before-commit: true   # NEVER auto-commit/merge. Human is always the merge gate.
                             # Escape hatch (kept by design): set false to auto-commit a
                             # fully-clean run (acceptance checklist all green). Even then
                             # autonomy NEVER pushes or merges — push stays a human action.
  max-blast-radius: 15       # park (back to plan gate) if blast radius exceeds N files
  park-on-touch:
    - "**/auth/**"
    - "**/payment/**"
    - "**/billing/**"
  respect-escalation: true   # park on a models.escalate-on trigger (architecture-finding, correctness-risk)

  # --- Run budget, hard ceiling (§5) ---
  budget:
    max-total-loops: 4
    max-stages: 12
    max-wall-clock-min: 60

  # --- Fix policy under autonomy (§8) ---
  auto-fix-severity: [critical, high]   # per-type loop count defers to feedback.max-loops

  # --- Operational safety (§6) ---
  require-clean-tree: true
  checkpoint: wip-commit     # none | wip-commit
  lock: true

  # --- Handoff (§10) ---
  report: ".temper/autonomy-report.md"
  notify: push-on-park       # none | push-on-park (default) | push-on-finish
                            # NOTE: "push" here = a desktop/phone notification, NOT git push.
                            # Autonomy NEVER does git push or merge under any setting.

# ============================================================
# Document-Driven Planning Intake (v6.2.0)
# Zero-config primary interface: --from <file|url|glean-link> / paste / link in prompt.
# Role is auto-detected from document content — no YAML required for the happy path.
# This block is OPTIONAL and power-user-only: absent = --from/paste/link with safe defaults.
# Auth: SSO / session only (Glean + bpages). No tokens or API keys anywhere in this config.
# ============================================================
# plan:
#   from-docs:
#     default-source: glean          # where to look first when a --from value is bare/relative
#     confidence-threshold: 0.7      # below this, Temper asks you to confirm at the plan gate
#     on-missing-role: elicit        # role with no doc => elicit natively | skip
#     on-drift: preserve             # unassignable content preserved verbatim + flagged (default)
#     pin:                           # rare: force a role when auto-detection gets YOUR template wrong
#       - match: "*/prd/*.md"        # path or URL glob
#         role: product-intent       # product-intent | solution-design | test-spec
#         adapter: fintech-regtech   # optional: force a coded adapter instead of `generic`

# ============================================================
# Booking Pages review publishing
# Publish the plan review to Booking Pages and read its comments back via the bpages CLI.
# Auth: run `bpages login` once (SSO, stored in the OS keychain) — the CLI handles auth.
# No tokens or keys live in this config.
# ============================================================
bpage:
  enabled: true               # false => bpage gate options hidden; local review unchanged
  access: booking             # published-page access: restricted | booking | holdings | public

# ============================================================
# IDE Support (v4.1.0)
# ============================================================

# Cursor IDE configuration
# Generate .cursor/ files from .claude/ source: python3 scripts/generate-cursor.py
ide:
  cursor:
    enabled: true
    gate-style: conversational    # conversational (numbered prompts) — Cursor has no AskUserQuestion
    orchestration: inline         # inline (sequential focus) — Cursor has no Agent subprocess tool
