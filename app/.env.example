# Local defaults for build-only and mock-mode checks.
# Copy to .env.local and replace placeholders with real values before auth,
# history, storage, or real AI/image manual testing.
#
# RAILWAY PRODUCTION CHECKLIST - BLACK FOREST LABS
# Railway does NOT read this file or app/.env.local. Add production values in:
# Railway > morning-analytics service > Variables > production environment.
#
# Required to make Black Forest Labs the production default:
#   IMAGE_GENERATION_PROVIDER=black-forest-labs
#   BLACK_FOREST_LABS_API_KEY=<real secret from dashboard.bfl.ai>
# Recommended explicit settings (the app has these defaults if omitted):
#   BLACK_FOREST_LABS_MODEL=flux-2-pro
#   BLACK_FOREST_LABS_API_BASE_URL=https://api.eu.bfl.ai/v1
#
# To ALSO show the provider picker in the app's Test view, copy both flags:
#   IMAGE_PROVIDER_TEST_OVERRIDE_ENABLED=true
#   NEXT_PUBLIC_IMAGE_PROVIDER_TEST_OVERRIDE_ENABLED=true
# Both flags are required: the first authorizes overrides on the server and the
# second makes the picker visible in the browser. The picker is optional and is
# not required for BFL to operate as the production default.
#
# After adding or changing Railway variables, review the purple staged changes
# and click Deploy. NEXT_PUBLIC_* values require this rebuild to reach browsers.
# Do not copy NEXT_PUBLIC_IMAGE_PROVIDER for new deployments; it is legacy only.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# Mocking (local/no-API testing; normally false in Railway production)
USE_AI_MOCKS=true
# REQUIRED in Railway: canonical production provider.
# Allowed values: mock, midjourney, or black-forest-labs.
IMAGE_GENERATION_PROVIDER=mock
# LEGACY only. IMAGE_GENERATION_PROVIDER takes precedence; new Railway
# deployments should use IMAGE_GENERATION_PROVIDER instead of this variable.
NEXT_PUBLIC_IMAGE_PROVIDER=mock
# OPTIONAL Test-view provider picker. Set BOTH to true in Railway to display and
# authorize the picker. Leave both false to hide provider switching in production.
IMAGE_PROVIDER_TEST_OVERRIDE_ENABLED=false
NEXT_PUBLIC_IMAGE_PROVIDER_TEST_OVERRIDE_ENABLED=false

# Gemini
GEMINI_API_KEY=placeholder-gemini-api-key
# GEMINI_MODEL=

# Discord + Midjourney
DISCORD_BOT_TOKEN=placeholder-discord-bot-token
DISCORD_CHANNEL_ID=placeholder-discord-channel-id
DISCORD_USER_TOKEN=placeholder-discord-user-token
DISCORD_GUILD_ID=placeholder-discord-guild-id
# MIDJOURNEY_APP_ID=936929561302675456
# MIDJOURNEY_IMAGINE_COMMAND_ID=938956540159881230

# Black Forest Labs
# Secret: enter the real value directly in Railway; never commit it.
BLACK_FOREST_LABS_API_KEY=placeholder-black-forest-labs-api-key
# Optional but recommended explicit production values. If omitted, the app uses
# flux-2-pro and https://api.eu.bfl.ai/v1.
BLACK_FOREST_LABS_MODEL=flux-2-pro
BLACK_FOREST_LABS_API_BASE_URL=https://api.eu.bfl.ai/v1
# BLACK_FOREST_LABS_IMAGE_WIDTH=1024
# BLACK_FOREST_LABS_IMAGE_HEIGHT=1024
# BLACK_FOREST_LABS_OUTPUT_FORMAT=jpeg
# BLACK_FOREST_LABS_POLL_INTERVAL_MS=1000
# BLACK_FOREST_LABS_TIMEOUT_MS=90000
# BLACK_FOREST_LABS_MAX_RETRIES=3

# Debugging
# DEBUG_DISCORD=true

# Admin cleanup script fallback
# SUPABASE_URL=https://example.supabase.co
